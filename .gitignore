# --- Composer dependencies ---------------------------------------------------
# These are restored automatically by running:  composer install
# (composer.json + composer.lock below are what tell Composer what to fetch.)
/vendor/*

# ...BUT keep the hand-placed legacy PHPMailer: it is NOT a Composer package,
# the app loads it via require_once('vendor/phpmailer/class.phpmailer.php'),
# so it must stay in Git or email will break.
!/vendor/phpmailer/

# Keep composer.lock in Git (do NOT ignore it) so everyone installs the exact
# same versions.

# --- CodeIgniter runtime junk ------------------------------------------------
/application/logs/*.php
/application/cache/*
!/application/cache/index.html

# --- Local-only dev files (must NOT reach production) ------------------------
# Presence of this flag makes database.php use the local XAMPP DB.
/application/config/is_local.flag
# Dev router for PHP's built-in server (php -S). Not used by Apache.
/router.php
# Double-click launcher for local development.
/start-local.bat
